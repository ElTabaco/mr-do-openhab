{
  "uid": "spotify_now_playing",
  "tags": [
    "spotify",
    "music",
    "now-playing"
  ],
  "props": {
    "parameters": [
      {
        "context": "item",
        "label": "Title Item",
        "name": "titleItem",
        "required": true,
        "type": "TEXT"
      },
      {
        "context": "item",
        "label": "Artist Item",
        "name": "artistItem",
        "required": false,
        "type": "TEXT"
      },
      {
        "context": "item",
        "label": "Image Item",
        "name": "imageItem",
        "required": false,
        "type": "TEXT"
      },
      {
        "context": "item",
        "label": "Action Item",
        "name": "actionItem",
        "required": false,
        "type": "TEXT"
      }
    ],
    "parameterGroups": []
  },
  "timestamp": "Jul 7, 2026, 9:47:25 AM",
  "component": "oh-card",
  "config": {
    "title": "=items[props.titleItem].state",
    "subtitle": "=items[props.artistItem].state",
    "footer": "Tap to play",
    "style": {
      "background-image": "=items[props.imageItem].state && items[props.imageItem].state !== 'NULL' ? 'url(' + items[props.imageItem].state + ')' : 'none'",
      "background-size": "cover",
      "background-position": "center",
      "min-height": "140px",
      "color": "white",
      "text-shadow": "0 1px 3px rgba(0,0,0,0.9)"
    },
    "action": "command",
    "actionItem": "=props.actionItem",
    "actionCommand": "ON"
  },
  "slots": {
    "default": []
  }
}